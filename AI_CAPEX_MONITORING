    # Skip if not M-F
    if datetime.now().weekday() >= 5:  # Saturday = 5, Sunday = 6
        print("⏸️  Weekend detected. Skipping (M-F only).")
        return
    
    # Fetch data
    print("📰 Fetching news...")
    news = fetch_recent_news(hours_back=24)
    
    print("📊 Checking stock movers...")
    movers = check_stock_movers(min_percent_change=5)
    
    print("⚠️  Checking IPO news...")
