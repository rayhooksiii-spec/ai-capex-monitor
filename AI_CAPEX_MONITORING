    print("📧 Generating report...")
    html_body = generate_html_report(news, movers, ipo, thesis_score)
    
    # Send alerts
    subject = f"[AI Capex] {thesis_score[1]} — {len(news)} articles, {len(movers)} movers, {len(ipo)} IPO alerts"
    
    print("\n📧 Sending email...")
    send_email(subject, html_body)
    
