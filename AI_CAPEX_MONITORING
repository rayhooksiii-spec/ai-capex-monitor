def send_email(subject, body_html):
    """Send via SendGrid (works around DigitalOcean SMTP block)."""
    if not SENDGRID_API_KEY or SENDGRID_API_KEY == "YOUR_SENDGRID_KEY":
        print(f"⚠️  SendGrid key not configured. Skipping email.")
        print(f"Subject: {subject}\n{body_html}\n")
        return False
    
    url = "https://api.sendgrid.com/v3/mail/send"
    headers = {
        "Authorization": f"Bearer {SENDGRID_API_KEY}",
        "Content-Type": "application/json"
    }
    
    data = {
        "personalizations": [{"to": [{"email": RECIPIENT_EMAIL}]}],
        "from": {"email": SENDER_EMAIL},
        "subject": subject,
        "content": [{"type": "text/html", "value": body_html}]
    }
    
    try:
        response = requests.post(url, json=data, headers=headers)
        if response.status_code == 202:
            print(f"✅ Email sent: {subject}")
            return True
        else:
            print(f"❌ SendGrid error: {response.status_code} - {response.text}")
            return False
    except Exception as e:
        print(f"❌ Email exception: {e}")
        return False

def send_slack_notification(message, color="warning"):
    """Send to Slack for in-app alert."""
    if not SLACK_WEBHOOK_URL:
        return False
    
    payload = {
        "attachments": [
            {
                "color": color,  # "good" (green), "warning" (yellow), "danger" (red)
                "title": "AI Capex Monitor Alert",
                "text": message,
                "ts": int(datetime.now().timestamp())
            }
        ]
    }
    
    try:
        requests.post(SLACK_WEBHOOK_URL, json=payload)
        print(f"✅ Slack notification sent")
        return True
    except Exception as e:
        print(f"❌ Slack exception: {e}")
        return False

