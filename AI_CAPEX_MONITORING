def fetch_recent_news(hours_back=24):
    """Fetch recent tech news mentioning capex keywords."""
    if not NEWSAPI_KEY or NEWSAPI_KEY == "YOUR_KEY":
        print("⚠️  NewsAPI key not configured. Skipping news fetch.")
        return []
    
    results = []
    url = "https://newsapi.org/v2/everything"
    
    # Build query: capex OR datacenter OR GPU OR ...
    query = " OR ".join(CAPEX_KEYWORDS[:5])  # Use first 5 to avoid query explosion
    
    params = {
        "q": query,
        "sortBy": "publishedAt",
        "language": "en",
        "apiKey": NEWSAPI_KEY,
        "pageSize": 20
    }
    
    try:
        response = requests.get(url, params=params, timeout=10)
        if response.status_code == 200:
            articles = response.json().get("articles", [])
            
            # Filter to last 24 hours
            cutoff = datetime.utcnow() - timedelta(hours=hours_back)
            for article in articles:
                pub_date = datetime.fromisoformat(article["publishedAt"].replace("Z", "+00:00"))
                if pub_date > cutoff:
                    results.append({
                        "title": article["title"],
                        "source": article["source"]["name"],
                        "url": article["url"],
                        "published_at": article["publishedAt"]
                    })
        else:
            print(f"⚠️  NewsAPI error: {response.status_code}")
    except Exception as e:
        print(f"⚠️  News fetch exception: {e}")
    
    return results

def check_stock_movers(min_percent_change=5):
    """Check if any of your holdings moved >5% overnight."""
    movers = []
    today = datetime.now().date()
    yesterday = today - timedelta(days=1)
    
    for ticker in list(HOLDINGS.keys()):
        try:
            stock = yf.Ticker(ticker)
            hist = stock.history(start=yesterday, end=today)
            if len(hist) >= 1:
                close = hist["Close"].iloc[-1] if len(hist) > 1 else None
                prev_close = hist["Close"].iloc[0] if len(hist) > 0 else None
                
                if close and prev_close:
                    pct_change = ((close - prev_close) / prev_close) * 100
                    if abs(pct_change) > min_percent_change:
                        movers.append({
                            "ticker": ticker,
                            "change_pct": round(pct_change, 2),
                            "price": round(close, 2)
                        })
        except:
            pass
    
    return movers

